# iuk-suite — Stack-Env (Modul-Präfixe für spätere Module: FILES_… / RADIO_… …)
AUTH_URL=https://iuk-ue.de
AUTH_SECRET=change-me-openssl-rand-base64-32
AUTH_COOKIE_DOMAIN=.iuk-ue.de
# Pocket ID (ein OIDC-Client für alle Suite-Domains)
POCKET_ID_ISSUER=https://id.iuk-ue.de
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=
POCKET_ID_SCOPES=openid profile email groups

# ── Prod-Domains der Module ───────────────────────────────────────────────────
# Ein Cutover ist damit eine Änderung in dieser Datei + `docker compose up -d`,
# kein Commit und kein CI-Lauf; ein Rollback ist das Zurücksetzen derselben
# Zeile. Die Werte kommen über `env_file` in den Container.
#
#   nicht gesetzt  → der Fallback aus core/registry.ts gilt
#   leer gesetzt   → das Modul hat KEINE Prod-Domain (Cutover zurückgenommen);
#                    es erscheint dann auch nicht im App-Switcher
#   mehrere Hosts  → kommagetrennt (z. B. das files-Modul mit fileshare + drop)
#
# Reiner Hostname, ohne Protokoll und ohne Port — sonst bricht der Boot ab.
# Ein Tippfehler im VARIABLENNAMEN bricht ebenfalls ab. Ein Tippfehler im WERT
# kann nicht erkannt werden: die Domain zeigt dann das Portal statt des Moduls.
# Deshalb nach jedem Cutover gegen die neue Domain curlen und prüfen, dass dort
# wirklich das erwartete Modul antwortet.
SUITE_HOST_PORTAL=iuk-ue.de
# SUITE_HOST_QR=
# SUITE_HOST_FEEDBACK=
# SUITE_HOST_FILES=
# SUITE_HOST_LAGERBUCH=
# SUITE_HOST_RADIO=

# Traefik muss dieselben Hosts an den Container leiten — sonst kommt die Domain
# gar nicht erst an. Beim Cutover eines Moduls hier mit erweitern:
#   SUITE_TRAEFIK_RULE=Host(`iuk-ue.de`) || Host(`qr.iuk-ue.de`)
SUITE_TRAEFIK_RULE=Host(`iuk-ue.de`)
